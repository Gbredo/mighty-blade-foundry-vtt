<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Nome da Armadura/Escudo" />
      </h1>

      <div class="grid grid-2col">
        <div class="resource">
          <label class="resource-label">Tipo</label>
          <select name="system.subtipo">
            <option value="armadura" {{#if (eq system.subtipo "armadura")}}selected{{/if}}>Armadura (Bloqueio + Esquiva)</option>
            <option value="escudo" {{#if (eq system.subtipo "escudo")}}selected{{/if}}>Escudo (só Bloqueio, ocupa 1 mão)</option>
          </select>
        </div>
        <div class="resource">
          <label class="resource-label">Defesa</label>
          <input type="number" name="system.defesa" value="{{system.defesa}}" data-dtype="Number" />
        </div>
      </div>
    </div>
  </header>

  <section class="sheet-body">
    <div class="grid grid-3col">
      <div class="resource flex-group-center">
        <label class="resource-label">FN (Força Nec.)</label>
        <input type="number" name="system.fn" value="{{system.fn}}" data-dtype="Number" />
      </div>
      <div class="resource flex-group-center">
        <label class="resource-label">Peso (kg)</label>
        <input type="number" name="system.peso" value="{{system.peso}}" data-dtype="Number" />
      </div>
      <div class="resource flex-group-center">
        <label class="resource-label">Custo</label>
        <input type="number" name="system.custo" value="{{system.custo}}" data-dtype="Number" />
      </div>
    </div>

    <div class="grid grid-2col">
      <label class="resource-label" style="display:flex;align-items:center;gap:6px;">
        <input type="checkbox" name="system.pesada" {{checked system.pesada}} style="width:auto;" /> Pesada (RD 1, Corrida ×2)
      </label>
      <label class="resource-label" style="display:flex;align-items:center;gap:6px;">
        <input type="checkbox" name="system.rigida" {{checked system.rigida}} style="width:auto;" /> Rígida / Restritiva
      </label>
    </div>

    <hr />

    <h3>Descrição / Observações</h3>
    <div class="editor-box">
      {{editor system.description target="system.description" rollData=rollData button=true owner=owner editable=editable}}
    </div>
  </section>
</form>
