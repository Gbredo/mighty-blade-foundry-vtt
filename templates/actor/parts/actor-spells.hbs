<ol class="items-list">
  <li class="item flexrow items-header">
    <div class="item-name">Magia</div>
    <div class="item-detail">Fonte</div>
    <div class="item-detail">PM</div>
    <div class="item-detail">DV</div>
    <div class="item-controls">
      <a class="item-control item-create" title="Criar magia" data-type="magia">
        <i class="fas fa-plus"></i> Magia
      </a>
    </div>
  </li>

  {{#each magias as |item id|}}
    <li class="item flexrow" data-item-id="{{item._id}}">
      <div class="item-name">
        <div class="item-image">
          <a class="rollable" data-roll-type="item" title="Conjurar (Shift = sem diálogo)">
            <img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
          </a>
        </div>
        <h4>{{item.name}}</h4>
      </div>
      <div class="item-detail">{{#if (eq item.system.fonte "mistica")}}Mística{{else}}Arcana{{/if}}</div>
      <div class="item-detail">{{item.system.custo}}</div>
      <div class="item-detail">{{item.system.dificuldade}}</div>
      <div class="item-controls">
        <a class="item-control item-edit" title="Editar"><i class="fas fa-edit"></i></a>
        <a class="item-control item-delete" title="Excluir"><i class="fas fa-trash"></i></a>
      </div>
    </li>
  {{/each}}
</ol>
