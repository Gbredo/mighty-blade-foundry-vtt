<form class="{{cssClass}} flexcol" autocomplete="off">

  {{!-- Cabeçalho --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Nome do NPC" />
      </h1>
      <div class="grid grid-2col">
        <div class="resource flex-group-center">
          <label class="resource-label">Tipo</label>
          <input type="text" name="system.details.tipo" value="{{system.details.tipo}}" placeholder="Ex.: Fera, Morto-vivo" />
        </div>
        <div class="resource flex-group-center">
          <label class="resource-label">Nível</label>
          <input type="number" name="system.details.nivel" value="{{system.details.nivel}}" data-dtype="Number" />
        </div>
      </div>
    </div>

    {{!-- Botão de edição (mostra/oculta criar/excluir de equipamentos) --}}
    <div class="sheet-config-container">
      <a class="sheet-config {{#if flags.mighty-blade.isEditing}}editing{{/if}}" title="{{#if flags.mighty-blade.isEditing}}Concluir edição{{else}}Habilitar edição{{/if}}">
        <i class="fas {{#if flags.mighty-blade.isEditing}}fa-check{{else}}fa-cog{{/if}}"></i>
      </a>
    </div>
  </header>

  {{!-- Abas --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="attributes">Principal</a>
    <a class="item" data-tab="features">Habilidades</a>
    <a class="item" data-tab="spells">Magias</a>
    <a class="item" data-tab="items">Itens</a>
    <a class="item" data-tab="effects">Efeitos</a>
  </nav>

  <section class="sheet-body">

    {{!-- Principal --}}
    <div class="tab attributes" data-group="primary" data-tab="attributes">

      {{!-- Atributos (clique no nome para rolar; valor editável) --}}
      <section class="grid grid-4col">
        <div class="flex-group-center">
          <label class="resource-label rollable" data-roll-type="attribute" data-attribute="forca" title="Rolar Teste de Força" style="cursor:pointer;">Força</label>
          <input type="number" class="resource-value" name="system.attributes.forca.value" value="{{system.attributes.forca.value}}" data-dtype="Number" />
        </div>
        <div class="flex-group-center">
          <label class="resource-label rollable" data-roll-type="attribute" data-attribute="agilidade" title="Rolar Teste de Agilidade" style="cursor:pointer;">Agilidade</label>
          <input type="number" class="resource-value" name="system.attributes.agilidade.value" value="{{system.attributes.agilidade.value}}" data-dtype="Number" />
        </div>
        <div class="flex-group-center">
          <label class="resource-label rollable" data-roll-type="attribute" data-attribute="inteligencia" title="Rolar Teste de Inteligência" style="cursor:pointer;">Inteligência</label>
          <input type="number" class="resource-value" name="system.attributes.inteligencia.value" value="{{system.attributes.inteligencia.value}}" data-dtype="Number" />
        </div>
        <div class="flex-group-center">
          <label class="resource-label rollable" data-roll-type="attribute" data-attribute="vontade" title="Rolar Teste de Vontade" style="cursor:pointer;">Vontade</label>
          <input type="number" class="resource-value" name="system.attributes.vontade.value" value="{{system.attributes.vontade.value}}" data-dtype="Number" />
        </div>
      </section>

      {{!-- Recursos --}}
      <section class="grid grid-2col">
        <div class="resource flex-group-center">
          <label class="resource-label">Pontos de Vida</label>
          <div class="resource-content flexrow flex-center flex-between">
            <input type="text" name="system.resources.vida.value" value="{{system.resources.vida.value}}" data-dtype="Number" />
            <span> / </span>
            <input type="text" name="system.resources.vida.max" value="{{system.resources.vida.max}}" data-dtype="Number" />
          </div>
        </div>
        <div class="resource flex-group-center">
          <label class="resource-label">Pontos de Mana</label>
          <div class="resource-content flexrow flex-center flex-between">
            <input type="text" name="system.resources.mana.value" value="{{system.resources.mana.value}}" data-dtype="Number" />
            <span> / </span>
            <input type="text" name="system.resources.mana.max" value="{{system.resources.mana.max}}" data-dtype="Number" />
          </div>
        </div>
      </section>

      <hr />

      {{!-- Sub-atributos derivados --}}
      <section class="grid grid-2col">
        <div class="flex-group-center">
          <label class="resource-label">Iniciativa</label>
          <span class="resource-value">{{system.subattributes.iniciativa.value}}</span>
        </div>
        <div class="flex-group-center">
          <label class="resource-label">Deslocamento</label>
          <span class="resource-value">{{system.subattributes.deslocamento.value}}</span>
        </div>
      </section>

      <hr />

      {{!-- Defesas (derivadas) + ajuste manual --}}
      <section class="grid grid-3col">
        <div class="flex-group-center">
          <label class="resource-label">Bloqueio</label>
          <span class="resource-value">{{system.defesas.bloqueio.value}}</span>
          <input type="number" name="system.defesasBonus.bloqueio" value="{{system.defesasBonus.bloqueio}}" data-dtype="Number" title="Bônus/penalidade manual" style="width:48px;" />
        </div>
        <div class="flex-group-center">
          <label class="resource-label">Esquiva</label>
          <span class="resource-value">{{system.defesas.esquiva.value}}</span>
          <input type="number" name="system.defesasBonus.esquiva" value="{{system.defesasBonus.esquiva}}" data-dtype="Number" title="Bônus/penalidade manual" style="width:48px;" />
        </div>
        <div class="flex-group-center">
          <label class="resource-label">Determinação</label>
          <span class="resource-value">{{system.defesas.determinacao.value}}</span>
          <input type="number" name="system.defesasBonus.determinacao" value="{{system.defesasBonus.determinacao}}" data-dtype="Number" title="Bônus/penalidade manual" style="width:48px;" />
        </div>
      </section>

      <hr />

      {{!-- Ataques (armas) --}}
      <h3>Ataques</h3>
      <ol class="items-list">
        {{#each gear as |item id|}}
          {{#if (eq item.type "arma")}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <a class="rollable" data-roll-type="item" title="Atacar (Shift = sem diálogo)"><img src="{{item.img}}" width="24" height="24" /></a>
                </div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-formula">{{item.system.dano}}</div>
              <div class="item-controls">
                <a class="item-control item-edit" title="Editar"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="Excluir"><i class="fas fa-trash"></i></a>
              </div>
            </li>
          {{/if}}
        {{/each}}
      </ol>

      <hr />

      <h3>Descrição</h3>
      <textarea name="system.details.descricao" rows="3" placeholder="Notas do mestre / descrição">{{system.details.descricao}}</textarea>
    </div>

    {{!-- Habilidades --}}
    <div class="tab features" data-group="primary" data-tab="features">
      {{> "systems/mighty-blade/templates/actor/parts/actor-features.hbs"}}
    </div>

    {{!-- Magias --}}
    <div class="tab spells" data-group="primary" data-tab="spells">
      {{> "systems/mighty-blade/templates/actor/parts/actor-spells.hbs"}}
    </div>

    {{!-- Itens --}}
    <div class="tab items" data-group="primary" data-tab="items">
      {{> "systems/mighty-blade/templates/actor/parts/actor-items.hbs"}}
    </div>

    {{!-- Efeitos --}}
    <div class="tab effects" data-group="primary" data-tab="effects">
      {{> "systems/mighty-blade/templates/actor/parts/actor-effects.hbs"}}
    </div>

  </section>
</form>
